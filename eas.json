{
  "cli": {
    "version": ">= 5.6.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      }
    },
    "internal": {
      "android": {
        "buildType": "app-bundle",
        "gradleCommand": ":app:bundleRelease"
      },
      "distribution": "internal"
    }
  },
  "submit": {
    "production": {},
    "internal": {
      "android": {
        "track": "internal",
        "releaseStatus": "completed",
        "rolloutPercentage": 100
      }
    }
  }
}
